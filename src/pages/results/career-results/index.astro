---
// COMPONENTS //
import Breadcrumbs from "@/components/ui/Breadcrumbs.astro";

// OTHERS //
import Layout from "@/layouts/Layout.astro";

// META //
import careerResultsMeta from "@/data/meta/results/career-results/career-results.json";

// COMPONENTS //
import CourseCard from "@/components/ui/CourseCard.astro";
import SectionHeaderMain from "@/components/ui/SectionHeaderMain.astro";
import EmptyState from "@/components/ui/EmptyState.astro";

// DATA //
import { careerResultsSectionHeader } from "@/data/results/career-results";
import { URLS } from "@/infrastructure/constants/urls";
import { careerResultsBreadcrumbs } from "@/data/results/career-results";

// API SERVICES //
import {
  fetchCareerExamsRequest,
} from "@/services/api/career-results.api.service";
import { fetchSessionsRequest } from "@/services/api/sessions.api.service";

const careerExams = await fetchCareerExamsRequest();
const careerSessions = await fetchSessionsRequest("results");
const fallbackSession = careerSessions[0]?.sessionName ?? "";
---

<Layout meta={careerResultsMeta}>
  <section class="bg-n-50 relative w-full overflow-hidden">
    <div
      class="container m-auto flex flex-col gap-9 px-5 pt-32 pb-14 md:gap-14 lg:gap-16 lg:pt-40"
    >
      <!-- Breadcrumbs Section -->
      <Breadcrumbs items={careerResultsBreadcrumbs} />

      <div class="flex flex-col gap-8 md:gap-12 lg:gap-14">
        <!-- Section Header -->
        <SectionHeaderMain
          title={careerResultsSectionHeader.title}
          subtitle={careerResultsSectionHeader.subtitle}
        />

        <!-- Courses -->
        <div
          class="grid grid-cols-1 gap-5 md:grid-cols-2 md:gap-6 lg:grid-cols-3"
        >
          {
            careerExams.length > 0 ? (
              careerExams.map((examItem) => {
                return (
                  <CourseCard
                    title={`${examItem.name} Results`}
                    image={examItem.cardImage}
                    onCtaClick={`window.location.href = "${URLS.RESULTS.CAREER_RESULTS.EXAM(examItem.slug)}?session=${encodeURIComponent(fallbackSession)}"`}
                    ctaText="Show Results"
                  />
                );
              })
            ) : (
              <EmptyState
                title="No Career Exams Found"
                description="We couldn't find any career exams right now. Please check back later."
              />
            )
          }
        </div>
      </div>
    </div>
  </section>
</Layout>
