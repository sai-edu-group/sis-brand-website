---
export const prerender = false; // Render on Server

// LAYOUT //
import Layout from "@/layouts/Layout.astro";

// COMPONENTS //
import FilterBar from "@/components/ui/FilterBar.astro";
import SectionHeaderMain from "@/components/ui/SectionHeaderMain.astro";
import Breadcrumbs from "@/components/ui/Breadcrumbs.astro";
import ResultsCard from "@/components/ui/ResultsCard.astro";
import EmptyState from "@/components/ui/EmptyState.astro";

// API SERVICES //
import {
  fetchCareerExamsRequest,
  fetchCareerResultsRequest,
} from "@/services/api/career-results.api.service";
import { fetchSessionsRequest } from "@/services/api/sessions.api.service";

// CONSTANTS //
import { URLS } from "@/infrastructure/constants/urls";

// ENUMS //
import { IMAGE_TYPES } from "@/enums/image.enum";

// UTILS //
import { generateImagePath } from "@/utils/image.utils";

// Get the Props from the URL [stream]/[year]
const { exam } = Astro.params;

const allCareerSessions = await fetchSessionsRequest("career-results");

const careerExams = await fetchCareerExamsRequest();
const currentExam = careerExams.find((examItem) => {
  return examItem.slug === exam;
});
const currentExamName = currentExam?.name || "";

// If exam is missing or invalid — go back or redirect
if (!exam || !currentExamName) {
  return new Response(null, {
    status: 302,
    headers: {
      Location: Astro.request.headers.get("referer") || URLS.HOME,
    },
  });
}

// Fetch results for all sessions in parallel, keep only sessions with data
const sessionResults = await Promise.all(
  allCareerSessions.map(async (sessionItem) => ({
    session: sessionItem,
    results: await fetchCareerResultsRequest(exam, sessionItem.sessionName),
  })),
);

const activeSessions = sessionResults.filter(
  (entry) => entry.results.length > 0,
);

const requestedSessionName =
  Astro.url.searchParams.get("session")?.trim() ?? "";
const fallbackSessionName = activeSessions[0]?.session.sessionName ?? "";

if (!fallbackSessionName) {
  return new Response(null, {
    status: 302,
    headers: {
      Location: Astro.request.headers.get("referer") || URLS.HOME,
    },
  });
}

// If requested session has no results, redirect to first session that does
const isValidSession = activeSessions.some(
  (entry) => entry.session.sessionName === requestedSessionName,
);

if (!requestedSessionName || !isValidSession) {
  return Astro.redirect(
    `${Astro.url.pathname}?session=${encodeURIComponent(fallbackSessionName)}`,
  );
}

const selectedSessionName = requestedSessionName;

const results =
  activeSessions.find(
    (entry) => entry.session.sessionName === selectedSessionName,
  )?.results ?? [];

// Breadcrumb Items
const breadcrumbItems = [
  { label: "Career Results", href: URLS.RESULTS.CAREER_RESULTS.ROOT },
  {
    label: currentExamName,
    href: `${URLS.RESULTS.CAREER_RESULTS.EXAM(exam)}?session=${encodeURIComponent(selectedSessionName)}`,
  },
];
---

<Layout meta={{ title: `${currentExamName} Results`, description: "Celebrating our students hard work and achievements" }}>
  <section class="bg-n-50 relative w-full overflow-hidden">
    <div
      class="container m-auto flex flex-col gap-10 px-5 pt-32 pb-14 md:gap-14 lg:gap-16 lg:pt-40"
    >
      <!-- Breadcrumbs -->
      <Breadcrumbs items={breadcrumbItems} />

      <!-- Body of the Results -->
      <div class="flex flex-col gap-8 md:gap-12 lg:gap-14">
        <!-- Section Header -->
        <SectionHeaderMain
          title={currentExamName}
          subtitle="Celebrating our students hard work and achievements"
        />

        <!-- Filter & Students -->
        <div class="flex flex-col gap-7 md:gap-8 lg:gap-11">
          <!-- Years Filters -->
          <FilterBar
            showSearch={false}
            years={activeSessions.map((entry) => ({
              value: entry.session.sessionName,
              label: entry.session.sessionName,
            }))}
            shouldIncludeCurrentYear={false}
            queryParamName="session"
          />

          <!-- Results -->
          {
            results && results.length > 0 ? (
              <div class="grid grid-cols-1 gap-5 md:grid-cols-2 md:gap-6 lg:grid-cols-3 xl:grid-cols-4">
                {results.map((resultItem) => (
                  <ResultsCard
                    studentName={resultItem.studentName}
                    image={generateImagePath(
                      resultItem.studentProfilePic,
                      IMAGE_TYPES.CAREER_RESULT,
                    )}
                  />
                ))}
              </div>
            ) : (
              <EmptyState
                title="No Results Found"
                description="We couldn't find any career results for the selected year. Please check back later."
              />
            )
          }
        </div>
      </div>
    </div>
  </section>
</Layout>
